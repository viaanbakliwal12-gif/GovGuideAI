# Core application
OPENAI_API_KEY=your_openai_api_key_here
SECRET_KEY=replace_with_a_long_random_value
FLASK_ENV=development
APP_ENV=development
# DATABASE_PATH=govguideai.sqlite3

# Supabase browser authentication. Use only the public publishable/anon key.
# Never put a service_role key or an sb_secret_ key here.
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_publishable_or_anon_key

# Legacy-account setup links created by an administrator.
# Allowed range: 5 to 120 minutes.
PASSWORD_SETUP_TOKEN_MINUTES=30

# Optional terminal-backup guard. Website setup does not require an email here.
ADMIN_EMAIL=

# Guest sessions
GUEST_SESSION_TTL_HOURS=24
