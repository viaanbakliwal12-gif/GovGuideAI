# Core application
OPENAI_API_KEY=your_openai_api_key_here
SECRET_KEY=replace_with_a_long_random_value
FLASK_ENV=development
APP_ENV=development
# DATABASE_PATH=govguideai.sqlite3

# Local OTP testing. This is refused unless the application is explicitly in development.
OTP_DEVELOPMENT_MODE=false
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_MAX_REQUESTS_PER_DESTINATION=5
OTP_MAX_REQUESTS_PER_IP=20
OTP_PEPPER=replace_with_a_separate_long_random_value
# Optional Fernet key. If omitted, a key is derived from SECRET_KEY.
OTP_DESTINATION_KEY=

# Email OTP (Resend)
EMAIL_PROVIDER=resend
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=

# Phone OTP (Twilio Verify)
SMS_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# One-time first-admin promotion guard
ADMIN_EMAIL=

# Guest sessions
GUEST_SESSION_TTL_HOURS=24
